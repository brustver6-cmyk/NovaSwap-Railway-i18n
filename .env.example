# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB?schema=public"

# Admin auth (bcrypt hash). Generate: node -e "console.log(require('bcryptjs').hashSync('your_password', 10))"
ADMIN_PASSWORD_HASH=""

# Branding
SITE_NAME="NovaSwap"
SUPPORT_TELEGRAM="@novaswap_support"
SUPPORT_EMAIL="support@example.com"

# Pricing
DEFAULT_MARKUP_PERCENT="1.5"
ORDER_RATE_LOCK_MINUTES="15"

# For production, set a long random secret:
AUTH_COOKIE_SECRET="change_me_to_long_random"
